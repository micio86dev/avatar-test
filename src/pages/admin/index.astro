---
import { getAllCandidates } from '../../lib/db';

export const prerender = false;

const candidates = getAllCandidates();

function fmt(iso: string | null): string {
  if (!iso) return '—';
  const d = new Date(iso);
  return Number.isNaN(d.getTime())
    ? iso
    : d.toLocaleDateString('it-IT', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Archivio Interviste</title>
  </head>
  <body>
    <main>
      <header>
        <h1>Archivio Interviste</h1>
        <a href="/" class="back">← Home</a>
      </header>

      {candidates.length === 0 && <p class="empty">Nessuna intervista registrata.</p>}

      {candidates.length > 0 && (
        <table>
          <thead>
            <tr>
              <th>Candidato</th>
              <th>Codice</th>
              <th>Progresso</th>
              <th>Sessioni</th>
              <th>Ultima attività</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {candidates.map((c) => {
              const completed = Number(c.completed_questions);
              const total = Number(c.total_questions);
              const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
              const done = completed === total && total > 0;
              return (
                <tr>
                  <td class="name">{c.display_name ?? '—'}</td>
                  <td class="code">{c.resume_code}</td>
                  <td class="progress">
                    <div class="bar-wrap">
                      <div class="bar-fill" style={`width:${pct}%`}></div>
                    </div>
                    <span class={`prog-label ${done ? 'done' : ''}`}>{completed}/{total}</span>
                  </td>
                  <td class="num">{c.session_count}</td>
                  <td class="date">{fmt(c.last_activity)}</td>
                  <td class="action">
                    <a href={`/admin/${c.resume_code}`} class="btn-detail">Dettaglio →</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </main>

    <style>
      :global(body) {
        margin: 0;
        background: #0b0c10;
        color: #e8eaed;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 32px 20px 64px;
      }
      header {
        display: flex;
        align-items: baseline;
        gap: 20px;
        margin-bottom: 28px;
      }
      h1 {
        margin: 0;
        font-size: 1.5rem;
      }
      .back {
        color: #6b7280;
        font-size: 0.85rem;
        text-decoration: none;
      }
      .back:hover { color: #9aa0aa; }
      .empty { color: #6b7280; }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
      }
      thead th {
        text-align: left;
        padding: 8px 12px;
        color: #6b7280;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #2a2c36;
      }
      tbody tr {
        border-bottom: 1px solid #1c1e27;
        transition: background 0.1s;
      }
      tbody tr:hover { background: #12131a; }
      td {
        padding: 12px 12px;
        vertical-align: middle;
      }
      .name { font-weight: 600; }
      .code {
        font-family: monospace;
        color: #a7f3d0;
        letter-spacing: 0.06em;
      }
      .progress {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 120px;
      }
      .bar-wrap {
        flex: 1;
        height: 6px;
        background: #2a2c36;
        border-radius: 3px;
        overflow: hidden;
      }
      .bar-fill {
        height: 100%;
        background: #10b981;
        border-radius: 3px;
        transition: width 0.3s;
      }
      .prog-label {
        color: #9aa0aa;
        font-size: 0.8rem;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
      }
      .prog-label.done { color: #10b981; }
      .num { color: #9aa0aa; text-align: center; }
      .date { color: #6b7280; font-size: 0.82rem; white-space: nowrap; }
      .action { text-align: right; }
      .btn-detail {
        display: inline-block;
        padding: 4px 14px;
        border: 1px solid #2a2c36;
        border-radius: 8px;
        color: #a7f3d0;
        font-size: 0.82rem;
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
      }
      .btn-detail:hover {
        border-color: #10b981;
        color: #10b981;
      }
    </style>
  </body>
</html>
