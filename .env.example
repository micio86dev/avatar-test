# BEAI Wrapper — environment example
# This file documents wrapper-level env vars (docker-compose overrides).
# Each app (api, frontend, backoffice) has its own .env.example in its own directory.
#
# Copy to .env and fill in values for local development:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# PostgreSQL (docker-compose service: postgres)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=beai
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis (docker-compose service: redis)
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mailpit (docker-compose service: mailpit)
# ---------------------------------------------------------------------------
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ---------------------------------------------------------------------------
# App service ports (used once app Dockerfiles are enabled in compose -- PR 5)
# ---------------------------------------------------------------------------
# API_PORT=8000
# FRONTEND_PORT=3000
# BACKOFFICE_PORT=3001
