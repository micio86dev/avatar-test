# ---------------------------------------------------------------------------
# Wrapper-level gitignore
# Each submodule (api/, frontend/, backoffice/) has its own .gitignore.
# ---------------------------------------------------------------------------

# dependencies (legacy-demo keeps its own node_modules)
node_modules/

# build output
dist/
.astro/
.vercel/

# local SQLite transcript store (legacy-demo reference data)
data/

# env — secrets never committed
.env
.env.*
!.env.example

# logs / os
*.log
.DS_Store
.vercel

# skill-registry local cache (machine-local fingerprint, not content)
.atl/.skill-registry.cache.json

# Docker / local dev artifacts
.docker/

# IDE
.idea/
.vscode/
*.swp
*.swo
