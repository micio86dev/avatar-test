APP_NAME=BEAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL — connect to the docker-compose beai service
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=beai
DB_USERNAME=beai
DB_PASSWORD=beai

# PostgreSQL test database (used by Pest via .env.testing)
# DB_DATABASE=beai_test

# Redis — connect to the docker-compose redis service
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — connect to the docker-compose mailpit service
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@beai.test"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# JWT — configure in C2 (auth is not wired in C1)
JWT_SECRET=
JWT_ALGO=HS256
