{
  "name": "frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "typecheck": "nuxi typecheck",
    "test:unit": "node node_modules/.bin/vitest run",
    "test:unit:coverage": "node node_modules/.bin/vitest run --coverage",
    "test:e2e": "node node_modules/.bin/playwright test",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "codegen": "bunx openapi-typescript openapi.json -o types/api.ts",
    "codegen:check": "bash scripts/check-client-drift.sh"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^9.0",
    "nuxt": "^4.4.8",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10",
    "@nuxt/eslint-config": "^1.16.0",
    "@playwright/test": "^1.52",
    "@tailwindcss/forms": "^0.5",
    "@tailwindcss/typography": "^0.5",
    "@tailwindcss/vite": "^4.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^3.0",
    "@vue/test-utils": "^2.4",
    "eslint": "^9.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1",
    "lint-staged": "^15.0",
    "openapi-typescript": "^7.0",
    "prettier": "^3.5",
    "tailwindcss": "^4.0",
    "typescript": "^5.8",
    "vitest": "^3.0",
    "vue-tsc": "^3.3.7"
  }
}
